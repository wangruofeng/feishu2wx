{
  "name": "feishu2wx",
  "version": "1.17.0",
  "description": "飞书文档转微信公众号排版工具",
  "private": true,
  "homepage": "/feishu2wx",
  "keywords": [
    "feishu",
    "wechat",
    "markdown",
    "editor"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "highlight.js": "^11.9.0",
    "markdown-it": "^13.0.1",
    "markdown-it-footnote": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "^5.0.1",
    "turndown": "^7.1.3",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build",
    "server": "ts-node --project server/tsconfig.json server/index.ts",
    "dev": "concurrently \"PORT=3100 npm start\" \"npm run server\"",
    "cf:dev": "concurrently \"CF_DEV=1 PORT=3100 react-scripts start\" \"sleep 5 && wrangler pages dev --proxy 3100 \"",
    "cf:deploy": "npm run build && npx wrangler pages deploy --branch main",
    "cf:kv:create": "npx wrangler kv namespace create CONFIG_KV && echo '' && echo '=== 请将输出的 ID 填入 wrangler.toml 中的 id 和 preview_id ==='",
    "pre-commit-check": "node scripts/pre-commit-check.js",
    "prepare": "test -x ./node_modules/.bin/husky && ./node_modules/.bin/husky || true",
    "postinstall": "test -x ./node_modules/.bin/patch-package && ./node_modules/.bin/patch-package || true"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260530.1",
    "@csstools/normalize.css": "^12.1.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "ajv": "^8.20.0",
    "concurrently": "^8.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "patch-package": "^8.0.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "wrangler": "^4.95.0"
  }
}
